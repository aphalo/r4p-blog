@Article{Bilger2001,
  author           = {Bilger, W. and Johnsen, T. and Schreiber, U.},
  journal          = {Journal of Experimental Botany},
  title            = {{UV}-excited chlorophyll fluorescence as a tool for the assessment of {UV}-protection by epidermins of plants},
  year             = {2001},
  number           = {363},
  pages            = {2007--2014},
  volume           = {52},
  abstract         = {Recently, a new method for estimating epidermal transmission of {UV} radiation in higher plants has been proposed. The empirical evidence for the usefulness of this method is reviewed here. Direct comparison with spectroscopically determined epidermal transmission yielded equivalent results. A linear correlation to the concentration of epidermal screening compounds has been shown. Relating {UV-A} and {UV-B} absorbance allowed some preliminary conclusions about the chemical nature of the screening compounds. A new portable apparatus is presented for the first time, which allows the non-destructive assessment of {UV-A} screening even under field conditions. Repeated measurements on identical leaves over a time-course of 6 d demonstrated a strong age-dependence in the capacity for the synthesis of {UV-A} screening compounds upon exposure to {UV-B} radiation. It is concluded that the new method may provide a valuable tool for the investigation of the acclimation of plants to {UV-B} radiation and, when accompanied by {HPLC} analysis, of the reaction of phenolic metabolism to environmental stimuli.},
  doi              = {10.1093/jexbot/52.363.2007},
  file             = {Bilger2001.pdf:reprints from others\\methods\\Bilger2001.pdf:PDF;Bilger2001.pdf:Reprints\\Articles\\Bilger2001.pdf:PDF},
  groups           = {Imported, Xuguang Sun, Methods},
  journaltitle     = {Journal of Experimental Botany},
  keywords         = {UV-B, ultraviolet-B, epidermal transmission, flavonoids, acclimation, fluorescence, chlorophyll, epidermis, UV-A-PAM},
  location         = {reprint pedro (7036)},
  modificationdate = {2026-05-20T22:09:39},
  owner            = {aphalo},
  subject          = {light},
  timestamp        = {2014.10.05},
}

@Article{Kolb2005,
  author    = {Kolb, C. A. and Schreiber, U. and Gademann, R. and Pf{\"{u}}ndel, E. E.},
  title     = {{UV-A} screening in plants determined using a new portable fluorimeter},
  journal   = {Photosynthetica},
  year      = {2005},
  volume    = {43},
  number    = {3},
  pages     = {371--377},
  doi       = {10.1007/s11099-005-0061-7},
  abstract  = {{UV} screening by plant surfaces can be determined by exposing plant organs to {UV} radiation and measuring the chlorophyll {(Chl)} fluorescence elicited. From this fluorescence, the {UV} transmittance can be derived: the more intense the screening the lower the reporter Chl fluorescence and the lower the {UV} transmittance. The relationships between {UV} screening at 375 nm, as determined in the field by a portable {UV-A-PAM} fluorimeter, and {UV} screening at 314 and 360 nm, measured in the laboratory with the non-portable {XE-PAM} fluorimeter, were investigated in leaves of grapevine {(Vitis} vinifera L. cv. Bacchus) and barley {(Hordeum} vulgare cv. Ricarda), as well as in white grape berries. With leaves, linear trends were observed between {XE-PAM} measurements at 314 nm and {UV-A-PAM} measurements at 375 nm but the relationship between transmittance at 360 and 375 nm in barley was curved: a simple model calculation suggests that this curvi-linearity arises from particularly weak absorbance of barley flavonoids at 375 nm relative to absorbance at 360 nm. Transmittance values at 314 nm plotted against 375 nm yielded a much smaller slope in grapevine leaves than in barley leaves, which was attributed to screening in the short-wavelength {UV} by hydroxycinnamic acids in the former but not in the latter species. With grape berries, a poor correlation was detected between transmittances at 314 and 375 nm which might arise from high scattering of {UV} radiation at the berry surface. Such artefacts appear to be confined to the {UV-B} region, as berry transmittance at 360 nm correlated very well with that at 375 nm. Thus, assessment of {UV} screening in the field at short {UV} wavelengths using 375 nm readings from a {UV-A-PAM} fluorimeter is possible provided that information is available on the relationship between the transmittance at the {UV} wavelength of interest and at 375 nm for the sample tissue being investigated.},
  file      = {Kolb2005PhotUVAPAM.pdf:Articles\\methods\\Kolb2005PhotUVAPAM.pdf:PDF;Kolb2005PhotUVAPAM.pdf:Articles\\00reprints unsorted\\Kolb2005PhotUVAPAM.pdf:PDF;Kolb2005PhotUVAPAM.pdf:Articles\\UVB\\Kolb2005PhotUVAPAM.pdf:PDF;Kolb2005a_A_nonlinearity.pdf:Articles\\UVB\\Kolb2005a_A_nonlinearity.pdf:PDF;Kolb2005PhotUVAPAM.pdf:reprints from others\\00reprints unsorted\\Kolb2005PhotUVAPAM.pdf:PDF;Kolb2005UVAPAMlinearity.pdf:Articles\\methods\\Kolb2005UVAPAMlinearity.pdf:PDF;Kolb2005PhotUVAPAM.pdf:reprints from others\\methods\\Kolb2005PhotUVAPAM.pdf:PDF;Kolb2005PhotUVAPAM.pdf:reprints from others\\UVB\\Kolb2005PhotUVAPAM.pdf:PDF;Kolb2005a_A_nonlinearity.pdf:reprints from others\\UVB\\Kolb2005a_A_nonlinearity.pdf:PDF;Kolb2005UVAPAMlinearity.pdf:reprints from others\\methods\\Kolb2005UVAPAMlinearity.pdf:PDF;Kolb2005UVAPAMlinearity.pdf:Reprints\\Articles\\Kolb2005UVAPAMlinearity.pdf:PDF;Kolb2005PhotUVAPAM.pdf:Reprints\\Articles\\Kolb2005PhotUVAPAM.pdf:PDF;Kolb2005.pdf:Reprints\\Articles\\Kolb2005.pdf:PDF;Kolb2005a_A_nonlinearity.pdf:Reprints\\Articles\\Kolb2005a_A_nonlinearity.pdf:PDF},
  groups    = {Imported},
  keywords  = {flavonoids, berry, Hordeum, barley, Vitis, grapevine, UV-A-PAM, fluorecence, methods, PAM, transmittance, fluorimeter, XE-PAM},
  location  = {reprint pedro (7169)},
  owner     = {aphalo},
  timestamp = {2014.10.06},
}


